// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Permission {
  VIEW
  EDIT
}

model User {
  userId             String           @id() @default(uuid()) @db.Uuid
  googleId           String?          @unique
  username           String           @db.VarChar(30)
  firstname          String
  lastname           String
  email              String           @unique
  password           String?
  tokenVersion       Int              @default(1)
  resetPasswordToken String?
  avatarUrl          String?          @db.Text
  createdAt          DateTime         @default(now())
  updateAt           DateTime?        @updatedAt
  document           Document?
  editableDocuments  UsersDocuments[]
}

model DocumentImage {
  imageId    String   @id @default(uuid()) @db.Uuid
  filename   String?
  document   Document @relation(fields: [documentId], references: [documentId])
  documentId String   @db.Uuid
  url        String   @db.Text
  createdAt  DateTime @default(now())
}

model Document {
  documentId      String           @id @default(uuid()) @db.Uuid
  title           String           @default("Untitled")
  documentContent Bytes?
  documentOwnerId String           @unique @db.Uuid
  documentOwner   User             @relation(fields: [documentOwnerId], references: [userId])
  documentEditors UsersDocuments[]
  documentImages  DocumentImage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime?        @updatedAt
  documentInvites DocumentInvite[]
}

model DocumentInvite {
  inviteId   String     @id @default(uuid()) @db.Uuid
  documentId String     @db.Uuid
  document   Document   @relation(fields: [documentId], references: [documentId])
  createdBy  String
  permission Permission @default(EDIT)
  inviteToken      String     @unique @default(uuid())
  expiresAt  DateTime
  usedBy     String?
  usedAt     DateTime?
  createdAt  DateTime   @default(now())
}

model UsersDocuments {
  userId     String     @db.Uuid
  user       User       @relation(fields: [userId], references: [userId])
  documentId String     @db.Uuid
  document   Document   @relation(fields: [documentId], references: [documentId])
  permission Permission @default(VIEW)

  @@id([userId, documentId])
}
