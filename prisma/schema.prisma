// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Permission {
  VIEW
  EDIT
  OWNER
}

model User {
  userId             String           @id() @default(uuid()) @db.Uuid
  googleId           String?          @unique
  username           String           @db.VarChar(30)
  firstname          String
  lastname           String
  email              String           @unique
  password           String?
  tokenVersion       Int              @default(1)
  resetPasswordToken String?
  avatarUrl          String?          @db.Text
  createdAt          DateTime         @default(now())
  updateAt           DateTime?        @updatedAt
  document           Document[]
  editableDocuments  UsersDocuments[]
  profileImage       Image?
}

model Image {
  imageId    String    @id @default(uuid()) @db.Uuid
  filename   String?
  user       User?     @relation(fields: [userId], references: [userId])
  userId     String?   @unique @db.Uuid
  document   Document? @relation(fields: [documentId], references: [documentId])
  documentId String?   @db.Uuid
  url        String    @db.Text
  createdAt  DateTime  @default(now())
}

model Document {
  documentId      String           @id @default(uuid()) @db.Uuid
  title           String           @default("Untitled")
  documentContent Bytes?
  documentPreview String?
  documentOwnerId String           @db.Uuid
  documentOwner   User             @relation(fields: [documentOwnerId], references: [userId])
  documentEditors UsersDocuments[]
  documentImages  Image[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime?        @updatedAt
  shareLinks      ShareLink[]
}

model ShareLink {
  linkId     String     @id @default(uuid()) @db.Uuid
  document   Document   @relation(fields: [documentId], references: [documentId])
  documentId String     @db.Uuid
  permission Permission
  expiresAt  DateTime
  createdAt  DateTime   @default(now())
}

model UsersDocuments {
  userId     String     @db.Uuid
  user       User       @relation(fields: [userId], references: [userId])
  documentId String     @db.Uuid
  document   Document   @relation(fields: [documentId], references: [documentId])
  permission Permission @default(VIEW)

  @@id([userId, documentId])
}
